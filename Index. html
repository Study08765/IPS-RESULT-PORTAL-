<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IPS PUBLIC SCHOOL Result Portal</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6fb;
}

header{
background:#0b3d91;
color:white;
text-align:center;
padding:20px;
}

header img{
width:120px;
margin-bottom:10px;
border-radius:50%;
}

.container{
width:95%;
max-width:500px;
margin:30px auto;
background:white;
padding:20px;
border-radius:12px;
box-shadow:0 0 15px rgba(0,0,0,.2);
}

input{
width:100%;
padding:12px;
font-size:18px;
margin-top:15px;
}

button{
width:100%;
padding:12px;
margin-top:15px;
background:#0b3d91;
color:white;
font-size:18px;
border:none;
cursor:pointer;
border-radius:5px;
}

button:hover{
background:#082d69;
}

#result{
margin-top:20px;
line-height:1.8;
}
</style>

</head>

<body>

<header>

<h1>IPS PUBLIC SCHOOL</h1>
<h3>AHIRORI HARDOI</h3>

<p>Annual Exam 2025-26</p>
<p><b>FINAL RESULT</b></p>

</header>

<div class="container">

<h2 align="center">Search Result</h2>

<input
type="text"
id="roll"
placeholder="Enter Roll Number">

<button onclick="searchResult()">

VIEW RESULT

</button>

<div id="result"></div>

</div>

<script>

const students={

1212:{
name:"Asmit Tripathi",
father:"-",
class:"7",
total:"281/350",
percentage:"80.28%",
rank:"1st",
result:"PASS"
},

1313:{
name:"Anshikha Kashyap",
father:"-",
class:"7",
total:"271/350",
percentage:"77.42%",
rank:"2nd",
result:"PASS"
},

1414:{
name:"Aditya Gupta",
father:"Hariom Gupta",
class:"7",
total:"245/350",
percentage:"70%",
rank:"3rd",
result:"PASS"
}

}

function searchResult(){

let roll=document.getElementById("roll").value;

let s=students[roll];

if(s){

document.getElementById("result").innerHTML=`

<hr>

<h2>${s.name}</h2>

<p><b>Roll No :</b> ${roll}</p>

<p><b>Father :</b> ${s.father}</p>

<p><b>Class :</b> ${s.class}</p>

<p><b>Total :</b> ${s.total}</p>

<p><b>Percentage :</b> ${s.percentage}</p>

<p><b>Rank :</b> ${s.rank}</p>

<p><b>Result :</b>

<font color="green">

${s.result}

</font>

</p>

`;

}

else{

document.getElementById("result").innerHTML=

"<h2 style='color:red'>Result Not Found</h2>";

}

}

</script>

</body>
</html>
